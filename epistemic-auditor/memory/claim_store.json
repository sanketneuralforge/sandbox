  "c6282df504507913b275b5c6a186f8a3": {
    "claim": "Vaccines cause autism",
    "result": {
      "claim_as_stated": "Vaccines cause autism",
      "atomic_claims": [
        "The Johns Hopkins Bloomberg School of Public Health states that vaccines do not cause autism.",
        "WHO expert group\u2019s new analysis reaffirms there is no link between vaccines and autism.",
        "CDC states that there is no evidence to accept or reject a causal relationship between DTaP and autism."
      ],
      "verdict": "MISLEADING",
      "confidence": 0.8,
      "evidence_summary": "The Johns Hopkins Bloomberg School of Public Health states that vaccines do not cause autism.: UNVERIFIABLE | WHO expert group\u2019s new analysis reaffirms there is no link between vaccines and autism.: TRUE | CDC states that there is no evidence to accept or reject a causal relationship between DTaP and autism.: UNVERIFIABLE",
      "sources": [
        {
          "title": "Andrew Wakefield",
